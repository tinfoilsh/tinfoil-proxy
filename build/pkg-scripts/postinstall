#!/bin/bash
# Post-install hook for the Tinfoil tray app.
# Launches the app once so the user lands in the tray immediately
# instead of having to find the app in /Applications first.

set -e

APP_PATH="/Applications/Tinfoil.app"
BIN="$APP_PATH/Contents/Resources/bin/tinfoil"

if [ -x "/usr/bin/chmod" ] && [ -f "$BIN" ]; then
  /usr/bin/chmod +x "$BIN" || true
fi

if [ -d "$APP_PATH" ]; then
  CONSOLE_USER=$(/usr/bin/stat -f%Su /dev/console 2>/dev/null || true)
  if [ -n "$CONSOLE_USER" ] && [ "$CONSOLE_USER" != "root" ]; then
    /usr/bin/sudo -u "$CONSOLE_USER" /usr/bin/open -a "$APP_PATH" >/dev/null 2>&1 || true
  fi
fi

exit 0
